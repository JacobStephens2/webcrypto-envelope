{
  "name": "@stephenspage/webcrypto-envelope",
  "version": "0.1.1",
  "description": "Tiny typed wrapper over the Web Crypto API: PBKDF2 password keys and AES-256-GCM encrypt/decrypt in a compact iv:tag:ciphertext envelope — plus seal/open for zero-knowledge shareable payloads.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "webcrypto",
    "web-crypto-api",
    "aes-gcm",
    "pbkdf2",
    "encryption",
    "e2ee",
    "end-to-end-encryption",
    "zero-knowledge",
    "offline-first",
    "browser"
  ],
  "author": "Jacob Stephens",
  "license": "MIT",
  "homepage": "https://github.com/JacobStephens2/webcrypto-envelope#readme",
  "bugs": {
    "url": "https://github.com/JacobStephens2/webcrypto-envelope/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JacobStephens2/webcrypto-envelope.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
